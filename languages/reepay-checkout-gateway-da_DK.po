#: ../includes/Gateways/ReepayCheckout.php:414
msgid "Order Handle Prefix"
msgstr "Ordre handle præfix"

#: ../includes/Gateways/ReepayCheckout.php:417
msgid ""
"Prefix for Frisbii order handles.<br><strong>Prefix \"order-\" makes the "
"order handle \"order-123456\", for example.</strong><br><br><strong>Note:</"
"strong> Add hyphen (-) or underscore (_) at the end if you want separation. "
"Maximum 8 characters allowed."
msgstr ""
"Præfix før Frisbii ordre handles.<br><strong>Med præfix \"order-\" bliver et "
"ordre handle \"order-123456\", for eksempel.</strong><br><br><strong>Bemærk:"
"</strong> Tilføj bindestreg (-) eller understregning (_), hvis der skal være "
"et mellemrum. Maksimalt 8 tegn tilladt."

#: ../includes/Gateways/ReepayCheckout.php:432
#, php-format
msgid ""
"Order handle prefix is too long (%1$d characters). Maximum allowed: %2$d "
"characters (reserving 12 for order number, total max: 20 characters as per "
"Frisbii API)."
msgstr ""
"Ordre handle præfiks er for langt (%1$d tegn). Maksimalt tilladt: %2$d tegn "
"(12 reserveret til ordrenummer, maks. 20 tegn i alt jf. Frisbii API)."

#: ../includes/Gateways/ReepayCheckout.php:442
#, php-format
msgid ""
"Invalid prefix \"%s\". Only these characters are allowed: Letters (a-z, "
"A-Z), Numbers (0-9), Hyphens (-), Underscores (_). Special characters like "
"@, #, $, !, spaces, etc. are not allowed."
msgstr ""
"Ugyldigt præfiks \"%s\". Kun disse tegn er tilladt: Bogstaver (a-z, A-Z), "
"tal (0-9), bindestreger (-), understregninger (_). Specialtegn som @, #, $, "
"!, mellemrum osv. er ikke tilladt."

#: ../includes/Gateways/ReepayCheckout.php:451
#, php-format
msgid ""
"Invalid prefix \"%s\". The prefix cannot start with a hyphen (-) or "
"underscore (_). Try adding letters or numbers at the beginning. Examples: "
"\"[order-]\", \"[order_]\""
msgstr ""
"Ugyldigt præfiks \"%s\". Præfikset kan ikke starte med en bindestreg (-) "
"eller understregning (_). Prøv at tilføje bogstaver eller tal i "
"begyndelsen. Eksempler: \"[order-]\", \"[order_]\""

#: ../includes/Gateways/ReepayCheckout.php:460
#, php-format
msgid ""
"Invalid prefix \"%s\". The prefix cannot contain consecutive hyphens (--) "
"or underscores (__). Use single hyphens or underscores only. Example: "
"\"[order-2024]\" instead of \"[order--2024]\""
msgstr ""
"Ugyldigt præfiks \"%s\". Præfikset kan ikke indeholde fortløbende "
"bindestreger (--) eller understregninger (__). Brug kun enkelte bindestreger "
"eller understregninger. Eksempel: \"[order-2024]\" i stedet for "
"\"[order--2024]\""

